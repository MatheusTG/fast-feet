generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DELIVERYMAN
}

model User {
  id        String    @id @default(uuid())
  cpf       String    @unique
  name      String
  password  String
  role      UserRole  @default(DELIVERYMAN)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  orders    Order[]

  @@map("users")
}

model Recipient {
  id                   String  @id @default(uuid())
  name                 String
  phone                String
  email                String
  deliveryInstructions String? @map("delivery_instructions")
  isProblematic        Boolean @default(false) @map("is_problematic")

  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String  @map("zip_code")
  latitude     Float?
  longitude    Float?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  orders    Order[]

  @@map("recipients")
}

enum OrderStatus {
  PENDING
  AWAITING_PICKUP
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  RETURNED
  CANCELED
}

model Order {
  id String @id @default(uuid())

  status OrderStatus @default(PENDING)

  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String  @map("zip_code")
  latitude     Float?
  longitude    Float?

  postedAt    DateTime  @default(now()) @map("posted_at")
  pickedUpAt  DateTime? @map("picked_up_at")
  deliveredAt DateTime? @map("delivered_at")
  returnedAt  DateTime? @map("returned_at")
  canceledAt  DateTime? @map("canceled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  recipientId   String  @map("recipient_id")
  deliverymanId String? @map("deliveryman_id")

  recipient   Recipient @relation(fields: [recipientId], references: [id])
  deliveryman User?     @relation(fields: [deliverymanId], references: [id])

  @@map("orders")
}
